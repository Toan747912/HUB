    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "swagger-typescript-api": "^13.12.3",
