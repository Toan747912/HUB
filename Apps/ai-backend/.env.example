# Local/dev: docker-compose's `postgres` service, or Supabase connection string.
# Supabase format (pooled, recommended for the app runtime):
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Supabase format (direct, required for `prisma migrate`):
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://ai_backend:dev-postgres-password-change-me@localhost:5432/ai_backend?schema=public"
