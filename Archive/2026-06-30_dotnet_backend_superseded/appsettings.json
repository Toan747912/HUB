{
  "ConnectionStrings": {
    "PostgreSQL": "Host=YOUR_SUPABASE_HOST;Port=5432;Database=YOUR_DATABASE;Username=YOUR_USERNAME;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },
  "Persistence": {
    "Mode": "EfCore"
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "https://YOUR_SUPABASE_PROJECT_ID.supabase.co/auth/v1",
      "Audience": "authenticated",
      "SigningKey": "YOUR_SUPABASE_JWT_SIGNING_KEY",
      "AccessTokenExpirationMinutes": 60,
      "Validation": {
        "ValidateIssuer": true,
        "ValidateAudience": true,
        "ValidateIssuerSigningKey": true,
        "ValidateLifetime": true
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
